# Phase 1a env vars — see ARCHITECTURE-saas.md §7
#
# Copy to .env.local (gitignored) and fill in real values from the source listed.
# All vars are validated at startup by env.ts (Zod). Missing/malformed values fail fast.

# --- Supabase ---
# Project URL and keys: Supabase Dashboard → Project Settings → API
# DATABASE_URL: pooler endpoint (Transaction mode), port 6543 — used by app at runtime
# DIRECT_URL:   direct connection, port 5432 — used by drizzle-kit migrations only
# Project Settings → Database → Connection string → URI (then swap to "Connection pooling" tab for pooler)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- Resend (email) ---
# API key: Resend Dashboard → API Keys
# Webhook secret: Resend Dashboard → Webhooks → (your endpoint) → Signing secret
RESEND_API_KEY=re_<key>
RESEND_WEBHOOK_SECRET=whsec_<secret>

# --- Upstash (rate limiting) ---
# Upstash Console → Redis database → REST API tab
UPSTASH_REDIS_REST_URL=https://<region>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# --- Sentry (error tracking) ---
# Sentry → Project Settings → Client Keys (DSN). Server-side only by default.
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# Optional: same DSN exposed to the browser for client-side error capture.
# Validated by env.ts as optional URL; if absent, instrumentation-client.ts no-ops.
# Set in Vercel (Preview + Production) so client-side capture works in deployed envs.
NEXT_PUBLIC_SENTRY_DSN=
# Build-time only — source map upload via next.config.ts. Not read at runtime.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- App ---
# Public URL of the app — used in email links etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bearer token for internal cron jobs (Vercel cron). Generate: openssl rand -hex 32
INTERNAL_CRON_SECRET=
