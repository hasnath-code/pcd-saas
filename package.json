{
  "name": "pcd-saas",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "tsx --conditions=react-server --env-file=.env.local db/seed/run.ts",
    "db:seed:local": "tsx --conditions=react-server --env-file=.env.local db/seed/run-local.ts",
    "screenshot": "tsx --env-file=.env.local scripts/screenshot.ts",
    "db:smoke": "node --env-file=.env.local scripts/smoke-pool.mjs",
    "db:cleanup-stubs": "tsx --env-file=.env.local scripts/cleanup-stub-webhook-events.ts",
    "db:cleanup-debt-037": "tsx --conditions=react-server --env-file=.env.local scripts/cleanup-debt-037-orphan-orgs.ts",
    "db:seed-pcd-surveyor": "tsx --env-file=.env.local scripts/seed-hasnath-pcd-surveyor.ts",
    "test:rls": "vitest run --config vitest.config.mts tests/rls",
    "test:actions": "vitest run --config vitest.config.mts tests/actions",
    "test:cloud-smoke": "CLOUD_SMOKE=1 vitest run --config vitest.config.mts tests/cloud-smoke"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.14.0",
    "next": "15.5.15",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.75.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "svix": "^1.92.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitest/ui": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "supabase": "^2.98.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
